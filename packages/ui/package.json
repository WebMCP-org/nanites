{
  "name": "@nanites/ui",
  "version": "0.0.0",
  "private": true,
  "description": "A React component library built for Nanites using Base UI",
  "homepage": "https://github.com/WebMCP-org/nanites",
  "bugs": {
    "url": "https://github.com/WebMCP-org/nanites/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/nanites.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": "./src/styles/index.css",
    "./styles/tokens": "./src/styles/tokens.css",
    "./styles/base": "./src/styles/base.css"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "test:a11y": "playwright test",
    "storybook": "storybook dev -p 6011",
    "build-storybook": "storybook build",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@base-ui/react": "~1.3.0",
    "@nanites/design-tokens": "workspace:*",
    "anser": "catalog:",
    "shiki": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/mocker": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
