{
  "name": "@nanites/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "typesVersions": {
    "*": {
      "auth": [
        "./src/auth.ts"
      ],
      "admin": [
        "./src/admin.ts"
      ],
      "nanites": [
        "./src/nanites.ts"
      ],
      "ids": [
        "./src/ids.ts"
      ]
    }
  },
  "exports": {
