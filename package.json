{
  "name": "nanites",
  "version": "0.0.0",
  "private": true,
  "description": "Durable GitHub maintenance agents on Cloudflare",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "github",
    "mcp"
  ],
  "homepage": "https://github.com/WebMCP-org/nanites#readme",
  "bugs": {
    "url": "https://github.com/WebMCP-org/nanites/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebMCP-org/nanites.git"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "ready": "vp check && vp test && vp build",
    "dev": "vp dev",
    "build": "vp build",
    "db:migrate": "vp run db:migrate:local",
    "db:migrate:local": "vp exec wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:migrate:remote": "node scripts/deploy-self-host.mjs --migrate-only",
    "db:migrate:prod": "vp exec wrangler d1 migrations apply DB --remote --config wrangler.production.jsonc",
    "deploy": "node scripts/deploy-self-host.mjs",
    "deploy:validate": "node scripts/deploy-self-host.mjs --validate",
    "deploy:preview": "vp build && vp exec wrangler versions upload dist/nanites_app_production/index.js --assets dist/client --tag $(git rev-parse --short HEAD) --config wrangler.production.jsonc",
    "deploy:prod": "VITE_SENTRY_ENVIRONMENT=production VITE_SENTRY_TRACES_SAMPLE_RATE=0.1 vp build && vp run db:migrate:prod && vp exec wrangler deploy dist/nanites_app_production/index.js --assets dist/client --config wrangler.production.jsonc",
    "test": "vp test",
    "test:e2e": "vp test -c tests/e2e/vitest.config.ts",
    "test:workers-integration": "vp run test:e2e",
    "types": "vp exec wrangler types env.d.ts --include-runtime false --strict-vars false --config wrangler.production.jsonc && vp fmt env.d.ts",
    "check": "vp check",
    "prepare": "vp config",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@base-ui/react": "~1.5.0",
    "@chat-adapter/github": "4.30.0",
    "@cloudflare/ai-chat": "^0.8.5",
    "@cloudflare/codemode": "^0.4.0",
    "@cloudflare/shell": "^0.4.0",
    "@cloudflare/think": "^0.9.0",
    "@cloudflare/worker-bundler": "^0.2.1",
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@hono/zod-validator": "^0.8.0",
    "@logtape/drizzle-orm": "^2.1.1",
    "@logtape/hono": "^2.1.1",
    "@logtape/logtape": "^2.1.1",
    "@logtape/redaction": "^2.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/oauth-methods": "^6.0.2",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/webhooks": "^14.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/cloudflare": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "agents": "^0.16.0",
    "ai": "^6.0.196",
    "chat": "4.30.0",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "hono": "^4.12.23",
    "hono-agents": "^3.0.11",
    "jose": "^6.2.3",
    "octokit": "^5.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260612.1",
    "@sentry/cli": "^3.5.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/router-plugin": "^1.168.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "react-doctor": "^0.5.1",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plus": "0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      },
      "ignoreMissing": [
        "@emnapi/core",
        "@emnapi/runtime"
      ]
    }
  }
}
