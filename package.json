{
  "name": "nanites",
  "version": "0.0.0",
  "private": true,
  "description": "Durable GitHub maintenance agents on Cloudflare",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "github",
    "mcp"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "ready": "vp check && vp test && vp build",
    "dev": "vp dev",
    "build": "vp build",
    "deploy": "vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc",
    "deploy:preview": "vp build && vp exec wrangler versions upload dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc",
    "deploy:staging": "CLOUDFLARE_ENV=staging VITE_SENTRY_ENVIRONMENT=staging VITE_SENTRY_TRACES_SAMPLE_RATE=0.2 vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc --env staging",
    "deploy:prod": "CLOUDFLARE_ENV=production VITE_SENTRY_ENVIRONMENT=production VITE_SENTRY_TRACES_SAMPLE_RATE=0.1 vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc --env production",
    "test": "vp test",
    "test:e2e": "vp test -c tests/e2e/vitest.config.ts",
    "test:workers-integration": "vp run test:e2e",
    "types": "vp exec wrangler types env.d.ts --include-runtime false && vp fmt env.d.ts",
    "check": "vp check",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@base-ui/react": "~1.3.0",
    "@chat-adapter/github": "4.29.0",
    "@cloudflare/ai-chat": "^0.7.2",
    "@cloudflare/codemode": "^0.3.8",
    "@cloudflare/shell": "^0.3.8",
    "@cloudflare/think": "^0.7.3",
    "@cloudflare/worker-bundler": "^0.1.3",
    "@cloudflare/workers-oauth-provider": "^0.7.0",
    "@logtape/drizzle-orm": "^2.0.5",
    "@logtape/logtape": "^2.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/oauth-methods": "^6.0.2",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/webhooks": "^14.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/cloudflare": "^10.55.0",
    "@sentry/react": "^10.55.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "agents": "^0.13.3",
    "ai": "^6.0.193",
    "chat": "4.29.0",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "hono-agents": "^3.0.11",
    "jose": "^6.2.3",
    "octokit": "^5.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20260601.1",
    "@sentry/cli": "^3.4.3",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/router-plugin": "^1.168.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.23",
    "vite-plus": "0.1.23",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.23",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      },
      "ignoreMissing": [
        "@emnapi/core",
        "@emnapi/runtime"
      ]
    }
  }
}
