# Copy to `.dev.vars` for local development. Do not commit `.dev.vars`.

AUTH_COOKIE_SECRET="replace-with-local-cookie-secret"
CLOUDFLARE_ACCOUNT_ID="replace-with-local-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="replace-with-local-cloudflare-api-token"
GITHUB_APP_ID="replace-with-local-github-app-id"
GITHUB_APP_SLUG="replace-with-local-github-app-slug"
GITHUB_APP_CLIENT_ID="replace-with-local-github-app-client-id"
GITHUB_APP_PRIVATE_KEY="replace-with-local-github-app-private-key"
GITHUB_APP_CLIENT_SECRET="replace-with-local-github-app-client-secret"
GITHUB_APP_WEBHOOK_SECRET="replace-with-local-github-app-webhook-secret"

# Required only when using ALLOW_TEST_AUTH=true for local MCP/browser smoke tests.
GITHUB_TEST_USER_TOKEN=""
