# Browser SDK and build-time settings only.
# Worker runtime secrets belong in .dev.vars locally and Wrangler secrets remotely.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=1
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# Build-time source map upload
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Keep this aligned with VITE_SENTRY_RELEASE when you want browser events and uploaded artifacts
# grouped under the same release.
SENTRY_RELEASE=
