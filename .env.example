# Required runtime bindings. Provisioned deployments receive real values from
# the external provisioner; this file exists so `wrangler types` emits them as
# required `Env` fields.
AUTH_COOKIE_SECRET="replace-with-auth-cookie-secret"
CLOUDFLARE_ACCOUNT_ID="replace-with-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"
GITHUB_APP_ID="replace-with-github-app-id"
GITHUB_APP_SLUG="replace-with-github-app-slug"
GITHUB_APP_CLIENT_ID="replace-with-github-app-client-id"
GITHUB_APP_PRIVATE_KEY="replace-with-github-app-private-key"
GITHUB_APP_CLIENT_SECRET="replace-with-github-app-client-secret"
GITHUB_APP_WEBHOOK_SECRET="replace-with-github-app-webhook-secret"
