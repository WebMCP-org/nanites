{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sigvelo-agent-tests",
  "main": "../../src/server.ts",
  "compatibility_date": "2026-03-02",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "worker_loaders": [
    {
      "binding": "LOADER",
    },
  ],
  "vars": {
    "ALLOW_TEST_AUTH": "true",
    "CLOUDFLARE_ACCESS_TEAM_DOMAIN": "",
    "CLOUDFLARE_ACCESS_AUD": "",
    "SENTRY_ENVIRONMENT": "test",
    "SENTRY_TRACES_SAMPLE_RATE": "0",
    "NANITES_LLM_FIXTURE": "complete",
    "GITHUB_APP_ID": "1",
    // Test-only generated RSA key. It is not connected to any GitHub App.
    "GITHUB_APP_PRIVATE_KEY": "-----BEGIN PRIVATE KEY-----\nMIICdwIBADANBgkqhkiG9w0BAQEFAASCAmEwggJdAgEAAoGBALO3J+D6jD7x60wu\n2U1GeSCgSdmYOOIAKmN1s4NI8Ehh7CBblLDJhRkcjaHeuwHu7HzBlZkARn8bMc6A\nZ2oHuPvvbVQOC0oO1V9hA4FGiSprTc3Thz/tDpkBHYaR0wrLpzwAzzsnZdAU+0fQ\nw0BxQkoQWfHwGOKpy6yEJwrdkkv3AgMBAAECgYAQtgFBTErqN3iXtuuB4gG1ZPI5\nB4ySh01pvjIZDRk6wdBBGgLzhWmY8izBVoKxJVRcLWwJtBraCt9QwmPbWih7LLhr\nVm5ItnfSDfAWxDh8+OEHJftN5kQKa/leVOiPspYBMu7vXw8ZuknWz6zO8oh3HOJL\nfE9z4VtEWBbhrYaHwQJBAOnRneMpMtZNCl1GGfT7TjXkPDlV+5odwJ3qTtP11XIt\n0l8UYBFYhImpWLsrNvnzJ2IsSVjiSjF5N8FEOBOEYzECQQDEw54E1t5PR11tLN1Z\ne6mSq9tpMQUTwzHy9kriy0mMpzYBgPSLJuMi/TLSkHME5w2ek3jCcVDE+0JLRzvL\nI0enAkAmmlj63B5siyOe6qf2blcnRps6zBtSAn9+kuSY0gl/ZFlLIU4LDxYytCbW\nH/hfo+lop+8kIZgmOuEdo2murzjBAkEAgA8EYAfr5dL/hheF9EAci/3Xre2ebU9D\nyenrsRE3TBhjeLUR8yKa/2Gk2w/yG8W4wnUeSgZv19PjQJUa4EmUzwJBANVg6dVU\nI7VowdV3HFyVFI3l135kySVWKK1+uroHOxjkaVIpHHUSknMhKz9eUJnYyncTSQMJ\n8RW9W1WyF0OX94c=\n-----END PRIVATE KEY-----",
    "GITHUB_CLIENT_ID": "test-client-id",
    "GITHUB_CLIENT_SECRET": "test-client-secret",
    "GITHUB_WEBHOOK_SECRET": "test-webhook-secret",
    "AUTH_COOKIE_SECRET": "test-auth-cookie-secret",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sigvelo-agent-tests",
      "database_id": "test-db",
      "migrations_dir": "../../src/backend/db/migrations",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "test-oauth-kv",
    },
    {
      "binding": "TOOL_OUTPUTS",
      "id": "b400bec1a47e4917816e8bf8628ce4f5",
    },
  ],
  "r2_buckets": [
    {
      "binding": "WORKSPACE_FILES",
      "bucket_name": "test-workspace-files",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "SigveloChatIngress",
        "name": "SigveloChatIngress",
      },
      // Test-harness-only binding: production only needs to export this class,
      // but vitest-pool-workers needs it here for sub-agent resolution.
      {
        "class_name": "ChatSdkStateAgent",
        "name": "ChatSdkStateAgent",
      },
      {
        "class_name": "SigveloManagerConversationAgent",
        "name": "SigveloManagerConversationAgent",
      },
      {
        "class_name": "SigveloNaniteManager",
        "name": "SigveloNaniteManager",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "SigveloChatIngress",
        "SigveloManagerConversationAgent",
        "SigveloNaniteManager",
        "SigveloNaniteAgent",
      ],
      "tag": "v1",
    },
  ],
}
