{
  "name": "nanites-app",
  "version": "1.0.0",
  "private": true,
  "description": "Nanites Cloudflare Worker app",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "deploy": "vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc",
    "deploy:preview": "vp build && vp exec wrangler versions upload dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc",
    "deploy:staging": "CLOUDFLARE_ENV=staging VITE_SENTRY_ENVIRONMENT=staging VITE_SENTRY_TRACES_SAMPLE_RATE=0.2 vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc --env staging",
    "deploy:prod": "CLOUDFLARE_ENV=production VITE_SENTRY_ENVIRONMENT=production VITE_SENTRY_TRACES_SAMPLE_RATE=0.1 vp build && vp exec wrangler deploy dist/nanites_app/index.js --assets dist/client --config wrangler.jsonc --env production",
    "test": "vp test",
    "test:e2e": "vp test -c tests/e2e/vitest.config.ts",
    "test:workers-integration": "vp run test:e2e",
    "types": "vp exec wrangler types env.d.ts --include-runtime false && vp fmt env.d.ts",
    "check": "vp check"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@chat-adapter/github": "catalog:",
    "@cloudflare/ai-chat": "catalog:",
    "@cloudflare/codemode": "catalog:",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/shell": "catalog:",
    "@cloudflare/think": "catalog:",
    "@cloudflare/worker-bundler": "catalog:",
    "@cloudflare/workers-oauth-provider": "catalog:",
    "@logtape/logtape": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@nanites/contracts": "workspace:*",
    "@nanites/db": "workspace:*",
    "@nanites/domain": "workspace:*",
    "@nanites/observability": "workspace:*",
    "@nanites/ui": "workspace:*",
    "@octokit/auth-app": "^8.1.2",
    "@octokit/oauth-methods": "^6.0.2",
    "@octokit/plugin-rest-endpoint-methods": "catalog:",
    "@octokit/request-error": "catalog:",
    "@octokit/webhooks": "^14.2.0",
    "@orpc/client": "catalog:",
    "@orpc/json-schema": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/react-query": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/cloudflare": "catalog:",
    "@sentry/react": "catalog:",
    "@streamdown/code": "^1.1.1",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "agent-skills-ts-sdk": "2.3.2",
    "agents": "catalog:",
    "ai": "^6.0.158",
    "chat": "catalog:",
    "cookie": "catalog:",
    "drizzle-orm": "catalog:",
    "gsap": "catalog:",
    "jose": "catalog:",
    "octokit": "^5.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@octokit/webhooks-methods": "catalog:",
    "@rolldown/plugin-babel": "^0.2.2",
    "@sentry/cli": "catalog:",
    "@sentry/vite-plugin": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "msw": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
