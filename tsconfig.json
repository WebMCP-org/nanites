{
  "extends": "agents/tsconfig",
  "compilerOptions": {
    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "include": [
    "env.d.ts",
    "env-extra.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["opensrc", "node_modules", "dist"]
}
