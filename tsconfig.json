{
  "extends": "agents/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "paths": {
      "@sigvelo/skill-links": ["./src/packages/skill-links/index.ts"],
      "#/*": ["./src/*"]
    }
  },
  "include": [
    "env.d.ts",
    "env-extra.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["opensrc", "node_modules", "dist"]
}
